# ─────────────────────────────────────────────────────────────
# Shelfora — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://yourapp.vercel.app
# Change this to your actual domain once deployed.
# In development: http://localhost:3000

# ── Database (Supabase / Neon recommended) ──────────────────
# Get from: https://supabase.com → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations — bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ── Auth ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars

# ── Email (Resend) ──────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM="Shelfora <alerts@yourdomain.com>"

# ── Stripe ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
# Get from: https://dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Stripe Price IDs — create these in Stripe dashboard:
# Product: "Shelfora Basic"  → Price: $19.99/month recurring
STRIPE_BASIC_PRICE_ID=price_xxxxxxxxxxxxxxxx
# Product: "Shelfora Pro"    → Price: $79.99/month recurring
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxx
# Product: "Shelfora Enterprise" → Price: $169.99/month recurring
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxx

# ── Webhook Security ────────────────────────────────────────
# Secret for validating POS webhook events.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your-webhook-secret-here

# ── Cron Security ───────────────────────────────────────────
# Protects the /api/cron/daily endpoint from public access.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here

# ── SMS (Twilio) ─────────────────────────────────────────────
# Get from: https://console.twilio.com
# Free trial gives ~$15 credit — enough to test fully
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# A Twilio phone number (buy one in console, ~$1/month)
TWILIO_FROM_NUMBER=+15550001234

# ── Admin Panel ──────────────────────────────────────────────
# Secret header for admin API endpoints (/api/admin/*)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=your-admin-secret-here
# Admin panel login credentials (used in shelfora.html admin login)
ADMIN_EMAIL=admin@shelfora.com
ADMIN_PASSWORD=change-this-in-production
